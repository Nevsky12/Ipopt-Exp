t": null, "author": null, "contributor": null}, {"id": "contrib_sipopt_doc_sipopt_manual_kkt_conditions", "label": "Karush-Kuhn-Tucker Conditions", "file_type": "concept", "source_file": "contrib/sIPOPT/doc/sipopt_manual.pdf", "source_location": "p. 2", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "contrib_sipopt_doc_sipopt_manual_implicit_function_theorem", "label": "Implicit Function Theorem", "file_type": "concept", "source_file": "contrib/sIPOPT/doc/sipopt_manual.pdf", "source_location": "pp. 2\u20133", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "contrib_sipopt_doc_sipopt_manual_kkt_sensitivity_system", "label": "Linearized KKT Sensitivity System", "file_type": "rationale", "source_file": "contrib/sIPOPT/doc/sipopt_manual.pdf", "source_location": "p. 3", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Applying the Implicit Function Theorem to the optimality conditions reduces sensitivity calculation to solving a linearized KKT system."}, {"id": "contrib_sipopt_doc_sipopt_manual_factorized_kkt_backsolve", "label": "Factorized KKT Backsolve", "file_type": "rationale", "source_file": "contrib/sIPOPT/doc/sipopt_manual.pdf", "source_location": "pp. 3\u20134", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "IPOPT already has the KKT matrix in factored form at the solution, so sensitivities and additional right-hand sides require only inexpensive backsolves."}, {"id": "contrib_sipopt_doc_sipopt_manual_licq", "label": "Linear Independence Constraint Qualification", "file_type": "concept", "source_file": "contrib/sIPOPT/doc/sipopt_manual.pdf", "source_location": "pp. 2\u20133", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "contrib_sipopt_doc_sipopt_manual_mfcq", "label": "Mangasarian-Fromovitz Constraint Qualification", "file_type": "concept", "source_file": "contrib/sIPOPT/doc/sipopt_manual.pdf", "source_location": "p. 2", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "contrib_sipopt_doc_sipopt_manual_strict_complementarity", "label": "Strict Complementarity", "file_type": "concept", "source_file": "contrib/sIPOPT/doc/sipopt_manual.pdf", "source_location": "p. 3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "contrib_sipopt_doc_sipopt_manual_ssosc", "label": "Strong Second-Order Sufficient Condition", "file_type": "concept", "source_file": "contrib/sIPOPT/doc/sipopt_manual.pdf", "source_location": "p. 3", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "contrib_sipopt_doc_sipopt_manual_artificial_parameter_encoding", "label": "Artificial Variable and Constraint Parameter Encoding", "file_type": "rationale", "source_file": "contrib/sIPOPT/doc/sipopt_manual.pdf", "source_location": "pp. 3\u20135", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Because IPOPT cannot distinguish variables from parameters, artificial variables and equality constraints expose parameters to the solver while preserving the original solution and sensitivity."}, {"id": "contrib_sipopt_doc_sipopt_manual_sequential_parameter_perturbations", "label": "Multiple Sequential Parameter Perturbations", "file_type": "rationale", "source_file": "contrib/sIPOPT/doc/sipopt_manual.pdf", "source_location": "p. 4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The same factorized KKT matrix can be reused with different right-hand sides, making multiple perturbation sensitivities inexpensive."}, {"id": "contrib_sipopt_doc_sipopt_manual_sensitivity_based_update", "label": "Sensitivity-Based Solution Update", "file_type": "concept", "source_file": "contrib/sIPOPT/doc/sipopt_manual.pdf", "source_location": "pp. 3\u201310", "source_url": null, "captured_at": null,